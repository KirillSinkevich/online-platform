{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "type": "module",
  "scripts": {
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f postgres",
    "db:studio": "cd apps/backend && npx prisma studio",

    "backend": "nx serve backend",
    "frontend": "nx serve web",

    "dev": "pnpm db:up && nx run-many -t serve --projects backend,web --parallel"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/angular": "22.3.3",
    "@nx/devkit": "22.4.4",
    "@nx/docker": "22.3.3",
    "@nx/esbuild": "22.3.3",
    "@nx/eslint": "22.3.3",
    "@nx/eslint-plugin": "22.3.3",
    "@nx/express": "22.3.3",
    "@nx/jest": "22.3.3",
    "@nx/js": "22.4.4",
    "@nx/node": "22.3.3",
    "@nx/playwright": "22.3.3",
    "@nx/vite": "22.3.3",
    "@nx/vitest": "22.4.4",
    "@nx/web": "22.3.3",
    "@nx/webpack": "22.3.3",
    "@nx/workspace": "22.3.3",
    "@playwright/test": "^1.36.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/utils": "^8.40.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.3.3",
    "prettier": "~3.6.2",
    "react-refresh": "^0.10.0",
    "supertest": "^7.1.4",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
